# OpenAI
OPENAI_API_KEY=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
OPENAI_ADMIN_KEY=
# Models
# Keep whisper-1 if you need verbose segment timestamps for tighter voiceover sync.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Prompt settings - leave blank to use the built-in production prompts
OPENAI_TRANSCRIPTION_PROMPT="This is a YouTube/video transcript. Preserve technical terms, names, numbers, and speaker meaning as accurately as possible."
TRANSLATION_SYSTEM_PROMPT="Return strict JSON only. Do not include markdown or explanations."
TRANSLATION_PROMPT_TEMPLATE="You are a professional subtitle translator and voiceover script editor. Translate the provided transcript segments into {target_language}. Preserve every id exactly. Do not merge, remove, or add segments. Keep the meaning accurate, natural, simple, and suitable for YouTube subtitles and AI voiceover. Return valid JSON only with this schema: {{\"segments\":[{{\"id\":1,\"target_text\":\"translated text\"}}]}}. Segments: {segments_json}"
TRANSLATION_REPAIR_PROMPT_TEMPLATE="Repair the following response into valid JSON only. Preserve exactly these segment IDs: {expected_ids}"
TTS_INSTRUCTIONS_TEMPLATE="Speak naturally and clearly in {target_language}. Use a friendly neutral YouTube voiceover style. Keep the pace close to the original timing. Do not add anything that is not in the text."

# Cost settings - update these from current OpenAI pricing when needed
OPENAI_TRANSCRIPTION_USD_PER_MIN=0.006
OPENAI_TEXT_INPUT_USD_PER_1M=0.15
OPENAI_TEXT_OUTPUT_USD_PER_1M=0.60
OPENAI_TTS_TEXT_INPUT_USD_PER_1M=0.60
OPENAI_TTS_AUDIO_OUTPUT_USD_PER_1M=12.00

# Backward-compatible aliases used by older copies of this project
WHISPER_1_USD_PER_MIN=0.006
GPT_4O_MINI_INPUT_USD_PER_1M=0.15
GPT_4O_MINI_OUTPUT_USD_PER_1M=0.60
GPT_4O_MINI_TTS_TEXT_INPUT_USD_PER_1M=0.60
GPT_4O_MINI_TTS_AUDIO_OUTPUT_USD_PER_1M=12.00

# Budget / balance guard
OPENAI_MONTHLY_BUDGET_USD=
OPENAI_MANUAL_AVAILABLE_BALANCE_USD=
COST_SAFETY_BUFFER_PERCENT=15

# Media processing
MAX_UPLOAD_MB=400
MAX_CHUNK_MB=22
AUDIO_BITRATE=64k
AUDIO_SAMPLE_RATE=24000
AUDIO_CHANNELS=1
OUTPUT_AUDIO_FORMAT=mp3

# Job/storage
JOBS_DIR=data/jobs
SQLITE_PATH=data/jobs/jobs.db
ALLOW_ONE_ACTIVE_JOB_ONLY=true
KEEP_INTERMEDIATE_FILES=true

# TTS sync
MAX_TTS_SEGMENT_TOKENS=1500
MAX_TTS_SPEEDUP=1.20
ALLOW_TTS_OVERLAP_SECONDS=0.35

# UI
APP_TITLE=مترجم الفيديو والتعليق الصوتي
DEFAULT_TARGET_LANGUAGES=ar,en
