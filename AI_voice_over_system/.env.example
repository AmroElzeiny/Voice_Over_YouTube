# OpenAI
OPENAI_API_KEY=
# Reserved for organization administration. It cannot return prepaid balance.
OPENAI_ADMIN_KEY=

# Models
# Keep whisper-1 if you need verbose segment timestamps for tighter voiceover sync.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Prompt settings - leave blank to use the built-in production prompts
OPENAI_TRANSCRIPTION_PROMPT="This is a YouTube/video transcript. Preserve technical terms, names, numbers, and speaker meaning as accurately as possible."
TRANSLATION_SYSTEM_PROMPT="Return strict JSON only. Do not include markdown or explanations."
TRANSLATION_PROMPT_TEMPLATE="You are a professional subtitle translator and voiceover script editor. Translate the provided transcript segments into {target_language}. Preserve every id exactly. Do not merge, remove, or add segments. Keep the meaning accurate, natural, concise, easy to speak, and suitable for YouTube subtitles and AI voiceover. Avoid robotic wording and unnecessary sentence expansion. Follow this language instruction: {language_instruction}. Return valid JSON only with this schema: {{\"segments\":[{{\"id\":1,\"target_text\":\"translated text\"}}]}}. Segments: {segments_json}"
TRANSLATION_REPAIR_PROMPT_TEMPLATE="Return valid JSON containing every requested segment exactly once. Use only these segment IDs: {expected_ids}"
TRANSLATION_BATCH_SIZE=20
TRANSLATION_RECOVERY_BATCH_SIZE=5
TTS_INSTRUCTIONS_TEMPLATE="Speak in a natural, warm, human-like YouTube voiceover style in {target_language}. Use clear pronunciation, natural pacing, and smooth sentence flow. Do not sound robotic. Do not add extra words. Keep the delivery close to the provided text. {style_instruction}"

# Cost settings - update these from current OpenAI pricing when needed
OPENAI_TRANSCRIPTION_USD_PER_MIN=0.006
OPENAI_TEXT_INPUT_USD_PER_1M=0.15
OPENAI_TEXT_OUTPUT_USD_PER_1M=0.60
OPENAI_TTS_TEXT_INPUT_USD_PER_1M=0.60
OPENAI_TTS_AUDIO_OUTPUT_USD_PER_1M=12.00
OPENAI_TTS_ESTIMATED_USD_PER_MIN=0.015
OPENAI_TTS_AUDIO_TOKENS_PER_SECOND=20

# Backward-compatible aliases used by older copies of this project
WHISPER_1_USD_PER_MIN=0.006
GPT_4O_MINI_INPUT_USD_PER_1M=0.15
GPT_4O_MINI_OUTPUT_USD_PER_1M=0.60
GPT_4O_MINI_TTS_TEXT_INPUT_USD_PER_1M=0.60
GPT_4O_MINI_TTS_AUDIO_OUTPUT_USD_PER_1M=12.00

# Budget / balance guard
# Set the opening balance once. The app subtracts its recorded API usage from it.
OPENAI_MONTHLY_BUDGET_USD=
OPENAI_MANUAL_AVAILABLE_BALANCE_USD=
COST_SAFETY_BUFFER_PERCENT=15

# Media processing
MAX_UPLOAD_MB=400
MAX_CHUNK_MB=22
AUDIO_BITRATE=64k
AUDIO_SAMPLE_RATE=24000
AUDIO_CHANNELS=1
OUTPUT_AUDIO_FORMAT=mp3

# Job/storage
JOBS_DIR=data/jobs
SQLITE_PATH=data/jobs/jobs.db
ALLOW_ONE_ACTIVE_JOB_ONLY=true
KEEP_INTERMEDIATE_FILES=true

# Logging
LOG_LEVEL=INFO
APP_LOG_PATH=data/logs/app.log

# YouTube diagnostics/authentication
# Use auto, deno, node, or quickjs. Deno is recommended by yt-dlp when available.
YT_DLP_JS_RUNTIME=auto
# Optional Netscape-format cookies file for restricted/authenticated videos.
YT_DLP_COOKIES_FILE=
# Optional local-only browser cookie source, for example: chrome or firefox.
YT_DLP_COOKIES_FROM_BROWSER=

# TTS sync
MAX_TTS_SEGMENT_TOKENS=1500
MAX_TTS_SPEEDUP=1.20
ALLOW_TTS_OVERLAP_SECONDS=0.35
TTS_BLOCK_MAX_CHARS=600
TTS_BLOCK_MAX_DURATION_SECONDS=14
TTS_MAX_INTERNAL_GAP_SECONDS=1.0
TTS_MAX_SILENCE_GAP_SECONDS=0.9
TTS_CROSSFADE_MS=60
TTS_REGEN_ON_QA_FAIL=true
TTS_QA_MAX_OVERLAP_SECONDS=0.05
TTS_QA_MAX_LONG_SILENCE_SECONDS=1.25
TTS_NATURALNESS_STYLE=warm_neutral
VOICE_SAMPLES_DIR=data/voice_samples

# UI
APP_TITLE=مترجم الفيديو والتعليق الصوتي
DEFAULT_TARGET_LANGUAGES=ar,en
